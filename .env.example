# ==============================================================================
# ENVIRONMENT VARIABLES - Sistema de Gestão de Estoque, Vendas e Locações
# ==============================================================================
# Copie este arquivo para .env e configure os valores de produção
# NUNCA commite o arquivo .env com dados sensíveis

# ==============================================================================
# NODE / SERVER
# ==============================================================================
NODE_ENV=development
PORT=3000

# ==============================================================================
# DATABASE TYPE & CONNECTION
# ==============================================================================

# Type: "mysql" ou "postgres" (default: mysql)
DB_TYPE=mysql

# ===== MYSQL =====
# Use these if DB_TYPE=mysql
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=1234
DB_NAME=sistema
DB_SSL=false

# ===== POSTGRESQL =====
# Use DATABASE_URL if DB_TYPE=postgres (recommended on Render)
# When using DATABASE_URL, DB_HOST/USER/PASSWORD/NAME are ignored
# Format: postgres://user:password@host:port/dbname
# Render provides DATABASE_URL automatically, so usually you don't need to set it
# DATABASE_URL=postgres://user:password@localhost:5432/sistema

# If you prefer individual connection variables (useful for local dev or manual
# configuration), set them as below — these will be used when DATABASE_URL is
# not provided. Ensure `DB_TYPE=postgres` is set.
DB_PORT=5432
# Example separated vars (uncomment and fill values if not using DATABASE_URL):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_NAME=sistema
# DB_SSL=true  # set to true when using SSL/TLS (Render Postgres typically requires it)

# ==============================================================================
# AUTHENTICATION (JWT)
# ==============================================================================
JWT_SECRET=seu_segredo_super_seguro_aqui
JWT_EXPIRES_IN=8h

# ==============================================================================
# LOGGING & MONITORING (optional)
# ==============================================================================
# LOG_LEVEL=info

# ==============================================================================
# API SETTINGS
# ==============================================================================
# CORS_ORIGIN=*
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

