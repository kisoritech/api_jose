################################################################################
# ENVIRONMENT VARIABLES - Sistema de Gestao de Estoque, Vendas e Locacoes
################################################################################
# Copie este arquivo para .env e preencha os valores reais.
# Nao versione credenciais reais.

################################################################################
# NODE / SERVER
################################################################################
NODE_ENV=development
PORT=3000

################################################################################
# DATABASE / POSTGRESQL
################################################################################
# A API continua usando PostgreSQL via driver `pg`.
# Para Supabase, o schema pode ser o mesmo do banco anterior.

# OPCAO 1 (recomendada para Supabase): string completa de conexao
# Pegue no painel do Supabase em:
# Project Settings > Database > Connection string
# SUPABASE_DB_URL=postgresql://postgres:[SENHA]@db.[PROJECT-REF].supabase.co:5432/postgres

# Alias generico ainda suportado para outras hospedagens
# DATABASE_URL=postgresql://postgres:[SENHA]@localhost:5432/sistema

# OPCAO 2: variaveis individuais para Supabase
# SUPABASE_PROJECT_REF=seu_project_ref
# SUPABASE_DB_HOST=db.seu_project_ref.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=sua_senha_supabase
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_SSL=true
# SUPABASE_DB_IP_FAMILY=4

# OPCAO 3: variaveis individuais genericas
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=sistema
DB_SSL=false
# DB_IP_FAMILY=4

# Pool de conexoes
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

################################################################################
# AUTHENTICATION (JWT)
################################################################################
JWT_SECRET=seu_segredo_super_seguro_aqui
JWT_EXPIRES_IN=8h

################################################################################
# API SETTINGS (opcional)
################################################################################
# CORS_ORIGIN=*
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
