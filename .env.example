# ==============================================================================
# ENVIRONMENT VARIABLES - Sistema de Gestão de Estoque, Vendas e Locações
# ==============================================================================
# Copie este arquivo para .env e configure os valores de produção
# NUNCA commite o arquivo .env com dados sensíveis

# ==============================================================================
# NODE / SERVER
# ==============================================================================
NODE_ENV=development
PORT=3000

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================

# OPÇÃO 1 (Recomendado): Use DATABASE_URL (fornecido automaticamente pelo Render)
# Formato: postgres://user:password@host:port/dbname
# DATABASE_URL=postgres://user:password@localhost:5432/sistema

# OPÇÃO 2: Configure as variáveis individuais (útil para desenvolvimento local)
# Use estes valores quando DATABASE_URL não for fornecido
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=sistema
DB_SSL=false  # true para SSL/TLS (Render PostgreSQL normalmente requer)

# ==============================================================================
# AUTHENTICATION (JWT)
# ==============================================================================
JWT_SECRET=seu_segredo_super_seguro_aqui
JWT_EXPIRES_IN=8h

# ==============================================================================
# LOGGING & MONITORING (optional)
# ==============================================================================
# LOG_LEVEL=info

# ==============================================================================
# API SETTINGS
# ==============================================================================
# CORS_ORIGIN=*
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

